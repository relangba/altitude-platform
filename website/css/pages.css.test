/* ===========================================
   Altitude Platform - Shared Pages CSS
   Version: 1.0
=========================================== */

/* ---------- Reset ---------- */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: "Segoe UI", Arial, Helvetica, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #f8f9fa;
}

/* ---------- Container ---------- */

.container {
    width: 90%;
    max-width: 1200px;
    margin: auto;
}

/* ---------- Navigation ---------- */

nav {
    background: #1b5e20;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
}

nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
}

.logo {
    color: white;
    font-size: 28px;
    font-weight: bold;
    text-decoration: none;
}

.menu {
    list-style: none;
    display: flex;
    gap: 25px;
}

.menu a {
    color: white;
    text-decoration: none;
    transition: .3s;
    padding-bottom: 4px;
}

.menu a:hover,
.menu a.active {
    color: #ffd54f;
    border-bottom: 2px solid #ffd54f;
}

/* ---------- Hero ---------- */

.hero {
    background: linear-gradient(rgba(0,0,0,.55),
                                rgba(0,0,0,.55)),
                url("../images/hero/hero.jpg");
    background-size: cover;
    background-position: center;
    color: white;
    text-align: center;
    padding: 120px 20px;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 20px;
}

.hero p {
    font-size: 1.2rem;
    max-width: 700px;
    margin: auto;
}

/* ---------- Sections ---------- */

section {
    padding: 70px 0;
}

section h2 {
    text-align: center;
    color: #1b5e20;
    margin-bottom: 25px;
}

section p {
    max-width: 900px;
    margin: auto;
    text-align: center;
}

/* ---------- Cards ---------- */

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
    gap: 25px;
    margin-top: 40px;
}

.card {
    background: white;
    border-radius: 10px;
    padding: 25px;
    box-shadow: 0 5px 15px rgba(0,0,0,.08);
    transition: .3s;
}

.card:hover {
    transform: translateY(-6px);
}

.card h3 {
    color: #2e7d32;
    margin-bottom: 15px;
}

.card p {
    text-align: left;
}

/* ---------- Buttons ---------- */

.btn {
    display: inline-block;
    background: #2e7d32;
    color: white;
    padding: 12px 25px;
    border-radius: 6px;
    text-decoration: none;
    transition: .3s;
}

.btn:hover {
    background: #1b5e20;
}

/* ---------- Gallery ---------- */

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
    gap: 20px;
}

.gallery img {
    width: 100%;
    border-radius: 8px;
    display: block;
}

/* ---------- Tables ---------- */

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 25px;
}

table th,
table td {
    border: 1px solid #ddd;
    padding: 12px;
}

table th {
    background: #2e7d32;
    color: white;
}

/* ---------- Forms ---------- */

input,
textarea,
select {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border-radius: 6px;
    border: 1px solid #ccc;
}

button {
    background: #2e7d32;
    color: white;
    padding: 12px 25px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

button:hover {
    background: #1b5e20;
}

/* ---------- Footer ---------- */

footer {
    background: #263238;
    color: white;
    text-align: center;
    padding: 35px 20px;
    margin-top: 60px;
}

/* ---------- Responsive ---------- */

@media (max-width:768px){

    nav .container{
        flex-direction:column;
    }

    .menu{
        flex-direction:column;
        text-align:center;
        margin-top:15px;
        gap:15px;
    }

    .hero{
        padding:80px 20px;
    }

    .hero h1{
        font-size:2.2rem;
    }

    .hero p{
        font-size:1rem;
    }
}
